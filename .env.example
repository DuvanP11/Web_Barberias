# Copia este archivo a `.env` y rellena los valores.

# --- Base de datos (PostgreSQL / Neon) ---
# DATABASE_URL: conexión POOLED (con -pooler en el host) — la usa la app en runtime.
DATABASE_URL="postgresql://usuario:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL: conexión DIRECTA (sin -pooler) — la usan `prisma db push` / migraciones.
DIRECT_URL="postgresql://usuario:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Autenticación ---
# Cadena larga y aleatoria para firmar las cookies de sesión (HMAC-SHA256).
AUTH_SECRET="genera-una-cadena-larga-y-aleatoria"

# --- Zona horaria del negocio (para horarios de citas) ---
TZ="America/Bogota"
