# Copia este archivo a `.env` y rellena los valores.

# --- Base de datos ---
# Desarrollo (SQLite, sin infraestructura):
DATABASE_URL="file:./dev.db"
# Producción (PostgreSQL / Neon): cambia el provider a "postgresql" en
# prisma/schema.prisma y usa una URL como:
# DATABASE_URL="postgresql://usuario:password@host/db?sslmode=require"

# --- Autenticación ---
# Cadena larga y aleatoria para firmar las cookies de sesión (HMAC-SHA256).
AUTH_SECRET="genera-una-cadena-larga-y-aleatoria"
